# --- System & Config ---
reload_config <C-r>
toggle_custom_color c
quit q
open_document o
# Closes menus/search bars
keyboard_overview <escape>

# --- Navigation ---
# Smooth half-page scrolling
screen_down <C-d>
screen_up <C-u>
goto_begining gg
goto_end G
# Back to previous position
pop_state <backspace>
# Follow links (press f, then the letter over the link)
overview_f <C-f>
toggle_fullscreen f

# --- View Modes ---
toggle_statusbar b
toggle_dark_mode d
fit_to_page_width w
goto_toc t
goto_page_with_page_number G
zoom_in  =
zoom_out -
rotate_clockwise R

# --- Highlights & Management ---
# Add highlight (select text, then press h)
add_highlight h
# DELETE: Hover mouse over a highlight and press x to remove it
delete_highlight x
# UNDO: Revert your last action
undo <A-u>
# Search and Bookmarks
search /
next_item n
previous_item N
show_bookmarks gb

# --- Portals (Researcher Mode) ---
portal p
edit_portal <C-p>
